{
    "version": 2,
    "name": "msme-admin-dashboard",
    "framework": "vite",
    "buildCommand": "cd frontend/admin_react && npm install && npm run build",
    "outputDirectory": "frontend/admin_react/dist",
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}